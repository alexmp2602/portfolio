---
const { href } = Astro.props;
---

<a
  href={href}
  role="link"
  class="inline-flex items-center justify-center gap-2 px-4 py-2 text-base font-medium transition
         rounded-xl max-w-fit border
         text-sky-800 bg-white border-amber-600 hover:bg-amber-600 hover:text-white
         dark:text-white dark:bg-gray-800 dark:border-yellow-400 dark:hover:bg-yellow-400 dark:hover:text-black
         focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-amber-500
         dark:focus-visible:ring-yellow-300"
>
  <slot />
</a>
